# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/watchfast?schema=public"

# ─── Better Auth ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-to-a-random-32-char-secret"
BETTER_AUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── TMDb ────────────────────────────────────────────────────────────────────
# themoviedb.org → Settings → API → Read Access Token (v4)
TMDB_READ_ACCESS_TOKEN=""

# ─── YouTube Data API v3 ──────────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Library → YouTube Data API v3 → Create Credentials
YOUTUBE_API_KEY=""

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="WatchFast AI"

# ─── AI Providers (optional — plug in later) ─────────────────────────────────
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# ─── Redis (optional — for future caching) ───────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Cloudinary (optional — for future image uploads) ────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
